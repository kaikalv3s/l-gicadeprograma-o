#include <iostream>
using namespace std;

int main() {
    
    float altura, pesoIdeal;
    int sexo;

    cout << "Digite sua altura: " << endl;
    cin >> altura;

    cout << "Digite seu sexo" <<endl <<"(1 - Masculino / 2 - Feminio): " << endl;
    cin >> sexo;

    if (sexo == 1) {
        pesoIdeal = (72.7 * altura) - 58;
        cout << "Peso ideal: " << pesoIdeal;
    } 
    else if (sexo == 2) {
        pesoIdeal = (62.1 * altura) - 44.7;
        cout << "Peso ideal: " << pesoIdeal;
    } 
    else {
        cout << "Opção invalida";
    }

    return 0;
}
