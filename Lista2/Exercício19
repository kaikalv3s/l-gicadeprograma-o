#include <iostream>
using namespace std;

int main() {
    int dia1, mes1, ano1;
    int dia2, mes2, ano2;

    cout << "Digite a primeira data (dia mes ano): ";
    cin >> dia1 >> mes1 >> ano1;

    cout << "Digite a segunda data (dia mes ano): ";
    cin >> dia2 >> mes2 >> ano2;

    if (ano1 > ano2) {
        cout << "A data maior é: " << dia1 << "/" << mes1 << "/" << ano1 << endl;
    } 
    else if (ano1 < ano2) {
        cout << "A data maior é: " << dia2 << "/" << mes2 << "/" << ano2 << endl;
    } 
    else {
        if (mes1 > mes2) {
            cout << "A data maior é: " << dia1 << "/" << mes1 << "/" << ano1 << endl;
        } 
        else if (mes1 < mes2) {
            cout << "A data maior é: " << dia2 << "/" << mes2 << "/" << ano2 << endl;
        } 
        else {
            if (dia1 > dia2) {
                cout << "A data maior é: " << dia1 << "/" << mes1 << "/" << ano1 << endl;
            } 
            else if (dia1 < dia2) {
                cout << "A data maior é: " << dia2 << "/" << mes2 << "/" << ano2 << endl;
            } 
            else {
                cout << "As datas são iguais!" << endl;
            }
        }
    }

    return 0;
}
