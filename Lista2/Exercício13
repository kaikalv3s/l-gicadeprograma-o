#include <iostream>
#include <cmath>
using namespace std;

int main() {
    float a, b, c, delta, x1, x2;

    cout << "Digite o valor de a: ";
    cin >> a;

    cout << "Digite o valor de b: ";
    cin >> b;

    cout << "Digite o valor de c: ";
    cin >> c;

    delta = (b * b) - (4 * a * c);

    if (delta < 0) {
        cout << "Nao existem raizes reais";
    } else {
        x1 = (-b + sqrt(delta)) / (2 * a);
        x2 = (-b - sqrt(delta)) / (2 * a);

        cout << "x1 = " << x1 << endl;
        cout << "x2 = " << x2 << endl;
    }

    return 0;
}
