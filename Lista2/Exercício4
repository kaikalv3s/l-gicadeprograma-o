#include <iostream>
using namespace std;

int main() {
    
    float salario, reajuste;
    const float aumento = 0.3;
    
    cout<<"Qual o seu salário atual? ";
    cin>>salario;
  
    if (salario <= 500) {
        reajuste = salario * aumento + salario;
        cout << "Seu novo salário será " <<reajuste <<endl;
    } 
    else {
        cout << "Você não tem direito ao aumento! ";
    }

    return 0;
}
