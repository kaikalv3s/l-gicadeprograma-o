#include <iostream>
using namespace std;

int main() {
    int A, B;

    cout << "Digite o valor de A: ";
    cin >> A;
    cout << "Digite o valor de B: ";
    cin >> B;

    if (A > B) {
        cout << "Diferença: " << A - B << endl;
    } else {
        cout << "Diferença: " << B - A << endl;
    }

    return 0;
}
