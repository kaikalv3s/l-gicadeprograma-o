#include <iostream>
using namespace std;

int main() {
    float n1, n2, n3, n4, n5, soma;

    cout << "Digite 5 notas (0 a 20): ";
    cin >> n1 >> n2 >> n3 >> n4 >> n5;

    if (n1 < 0 || n1 > 20 || n2 < 0 || n2 > 20 || n3 < 0 || n3 > 20 ||
        n4 < 0 || n4 > 20 || n5 < 0 || n5 > 20) {
        cout << "Nota invalida!" << endl;
    } else {
        soma = n1 + n2 + n3 + n4 + n5;

        if (soma >= 70) {
            cout << "Aprovado!" << endl;
        } else if (soma >= 30) {
            cout << "Exame!" << endl;
        } else {
            cout << "Reprovado!" << endl;
        }

        cout << "Soma: " << soma << endl;
    }

    return 0;
}
