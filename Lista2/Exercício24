#include <iostream>
using namespace std;

int main() {
    float n1, n2, n3, media, recuperacao, nova_media;

    cout << "Digite a primeira nota: ";
    cin >> n1;

    cout << "Digite a segunda nota: ";
    cin >> n2;

    cout << "Digite a terceira nota: ";
    cin >> n3;

    media = (n1 + n2 + n3) / 3;

    if (media >= 6) {
        cout << "Aprovado!" << endl;
        cout << "Media: " << media << endl;
    } else {
        cout << "Digite a nota da recuperacao: ";
        cin >> recuperacao;

        nova_media = (media + recuperacao) / 2;

        if (nova_media >= 6) {
            cout << "Aprovado na recuperacao!" << endl;
            cout << "Media: " << nova_media << endl;
        } else {
            cout << "Reprovado!" << endl;
            cout << "Media: " << nova_media << endl;
        }
    }

    return 0;
}
