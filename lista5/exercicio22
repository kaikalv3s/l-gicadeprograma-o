#include <iostream>
using namespace std;

float potencia(float x, int expoente)
{
    float p = 1;

    for(int i = 0; i < expoente; i++)
    {
        p = p * x;
    }

    return p;
}

int fatorial(int n)
{
    int fat = 1;

    for(int i = 1; i <= n; i++)
    {
        fat = fat * i;
    }

    return fat;
}

int main()
{
    int n;          
    float x;        
    float s = 0;    

    int expoente = 2;  
    int den = 1;       
    int direcao = 1;  

    cout << "Digite a quantidade de termos: ";
    cin >> n;

    cout << "Digite o valor positivo de X: ";
    cin >> x;

    for(int i = 1; i <= n; i++)
    {
        float termo = potencia(x, expoente) / fatorial(den);

        if(i % 2 != 0)
        {
            s = s - termo;
        }
        else
        {
            s = s + termo;
        }

        expoente++;

        den = den + direcao;

        if(den == 4)
        {
            direcao = -1;
        }
        else if(den == 1)
        {
            direcao = 1;
        }
    }

    cout << "Valor de S = " << s;

    return 0;
}

