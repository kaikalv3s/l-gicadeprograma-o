#include <iostream>
using namespace std;

int main()
{
    int x, y;
    long long resultado = 1;

    cout << "Digite o valor de x: ";
    cin >> x;

    cout << "Digite o valor de y: ";
    cin >> y;

    if (y < 0)
    {
        cout << "Este programa não aceita expoente negativo." << endl;
    }
    else
    {
        for (int i = 1; i <= y; i++)
        {
            resultado *= x;
        }

        cout << "Resultado de " << x << "^" << y << " = " << resultado << endl;
    }

    return 0;
}
