#include <iostream>
using namespace std;

int fatorial(int n)
{
    int f = 1;
    for (int i = 1; i <= n; i++)
        f *= i;
    return f;
}

int main()
{
    int n;
    float E = 1;

    cout << "Digite N: ";
    cin >> n;

    for (int i = 1; i <= n; i++)
        E += 1.0 / fatorial(i);

    cout << "Resultado: " << E;
}
