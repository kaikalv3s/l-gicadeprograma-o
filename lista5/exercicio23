#include <iostream>
using namespace std;

int main ()
{
    int a, b, c;
    int soma = 0;

    cout << "Digite o valor de A (maior do que 1): ";
    cin >> a;

    cout << "Digite o valor de B: ";
    cin >> b;

    cout << "Digite o valor de C: ";
    cin >> c;

    if (a < 2)
    {
        cout << "Erro! Valor de \"a\" invalido";
    }
    else
    {
        for (int i = b + 1; i < c; i++)
        {
            if (i % a == 0)
            {
                soma = soma + i;
            }
        }

        cout << "A soma dos numeros entre B e C divisiveis por A é: " << soma;
    }

    return 0;
}

