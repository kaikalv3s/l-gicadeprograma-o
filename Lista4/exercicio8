#include <iostream>
using namespace std;

int produto (int n1, int n2){
    if (n2 == 0){
    return 0;
    }
    return 1 + produto(n1, n2 -1);
}

int main (){
    int n1, n2;
    cout<<"Digite o primeiro valor: ";
    cin>> n1;
    cout<<"Digite o segundo valor: ";
    cin>>n2;
    cout<<"O produto é: " <<produto(n1, n2) <<endl;
    
    
    return 0;
}
