#include <iostream>
using namespace std;

int fibonacci(int n) {
    if (n == 0) {
        return 0;
    }
    if (n == 1) {
        return 1;
    }

    return fibonacci(n - 1) + fibonacci(n - 2);
}

int main() {
    int n;

    cout << "Digite o valor de n: ";
    cin >> n;

    cout << "O " << n << "º termo da sequencia de Fibonacci é: " << fibonacci(n) << endl;

    return 0;
}
