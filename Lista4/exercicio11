#include <iostream>
using namespace std;

int maior, menor; // variáveis globais

void compara(int a, int b){
    if (a > b){
        maior = a;
        menor = b;
    } else {
        maior = b;
        menor = a;
    }
}

int main(){
    int a, b;

    cout << "Digite dois numeros: ";
    cin >> a >> b;

    compara(a, b);

    cout << "Maior: " << maior << endl;
    cout << "Menor: " << menor << endl;

    return 0;
}
