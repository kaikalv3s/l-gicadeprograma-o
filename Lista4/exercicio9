#include <iostream>
using namespace std;

int mdc(int a, int b){
    if(b == 0){
        return a;
    }
    return mdc(b, a % b);
}

int main(){
    int a, b;

    cout << "Digite o primeiro numero: ";
    cin >> a;

    cout << "Digite o segundo numero: ";
    cin >> b;

    cout << "O MDC é: " << mdc(a, b) << endl;

    return 0;
}
