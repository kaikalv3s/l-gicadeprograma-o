#include <iostream>
using namespace std;

int potencia (int a, int n){
    if (n == 0){
    return 1;
    }
    return a * potencia (a, n - 1);
}

int main() {
    int a, n;

    cout << "Digite a base: ";
    cin >> a;

    cout << "Digite o expoente: ";
    cin >> n;

    int resultado = potencia(a, n);

    cout << "Resultado: " << resultado << endl;

    return 0;
}
