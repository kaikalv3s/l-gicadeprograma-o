#include <iostream>
using namespace std;

void ordenar_chars(char &ch1, char &ch2, char &ch3) {
    char menor, meio, maior;

    if (ch1 <= ch2 && ch1 <= ch3) {
        menor = ch1;
        if (ch2 <= ch3) { meio = ch2; maior = ch3; }
        else { meio = ch3; maior = ch2; }
    } else if (ch2 <= ch1 && ch2 <= ch3) {
        menor = ch2;
        if (ch1 <= ch3) { meio = ch1; maior = ch3; }
        else { meio = ch3; maior = ch1; }
    } else {
        menor = ch3;
        if (ch1 <= ch2) { meio = ch1; maior = ch2; }
        else { meio = ch2; maior = ch1; }
    }

    ch1 = menor;
    ch2 = meio;
    ch3 = maior;
}

int main() {
    char ch1, ch2, ch3;

    cout << "Digite três caracteres: ";
    cin >> ch1 >> ch2 >> ch3;

    ordenar_chars(ch1, ch2, ch3);

    cout << "Ordenados: " << ch1 << " " << ch2 << " " << ch3 << endl;

    return 0;
}
