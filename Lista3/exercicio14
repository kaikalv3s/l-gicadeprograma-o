#include <iostream>
using namespace std;

int quadrante(int angulo) {
    angulo = angulo % 360; // normaliza para [0, 359]

    if (angulo == 0 || angulo == 90 || angulo == 180 || angulo == 270 || angulo == 360) {
        return 0;
    } else if (angulo > 0 && angulo < 90) {
        return 1;
    } else if (angulo > 90 && angulo < 180) {
        return 2;
    } else if (angulo > 180 && angulo < 270) {
        return 3;
    } else if (angulo > 270 && angulo < 360) {
        return 4;
    } else {
        return 0; // caso não esteja em nenhum quadrante
    }
}

int main() {
    int angulo;
    cout << "Digite um ângulo em graus: ";
    cin >> angulo;

    int resultado = quadrante(angulo);

    if (resultado == 0) {
        cout << "O ângulo está sobre um eixo, não pertence a nenhum quadrante." << endl;
    } else {
        cout << "O ângulo está no quadrante " << resultado << "." << endl;
    }

    return 0;
}
